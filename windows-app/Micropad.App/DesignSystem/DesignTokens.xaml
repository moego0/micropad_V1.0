<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Spacing scale: 4 / 8 / 12 / 16 / 24 -->
    <Thickness x:Key="Spacing4">4</Thickness>
    <Thickness x:Key="Spacing8">8</Thickness>
    <Thickness x:Key="Spacing12">12</Thickness>
    <Thickness x:Key="Spacing16">16</Thickness>
    <Thickness x:Key="Spacing24">24</Thickness>
    <Thickness x:Key="Padding4">4</Thickness>
    <Thickness x:Key="Padding8">8</Thickness>
    <Thickness x:Key="Padding12">12</Thickness>
    <Thickness x:Key="Padding16">16</Thickness>
    <Thickness x:Key="Padding24">24</Thickness>

    <!-- Corner radius: 4 / 8 / 10 / 12 (standard 10) -->
    <CornerRadius x:Key="Radius4">4</CornerRadius>
    <CornerRadius x:Key="Radius8">8</CornerRadius>
    <CornerRadius x:Key="Radius10">10</CornerRadius>
    <CornerRadius x:Key="Radius12">12</CornerRadius>

    <!-- Typography: use as StaticResource. Set Foreground in view or inherit. -->
    <Style x:Key="CaptionText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
    </Style>
    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style x:Key="SubtitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style x:Key="TitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Elevation shadows (soft) -->
    <DropShadowEffect x:Key="ShadowCard" Color="Black" BlurRadius="12" ShadowDepth="2" Opacity="0.15"/>
    <DropShadowEffect x:Key="ShadowCardHover" Color="Black" BlurRadius="16" ShadowDepth="3" Opacity="0.2"/>
    <DropShadowEffect x:Key="ShadowFocusRing" Color="#0078D4" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
</ResourceDictionary>
