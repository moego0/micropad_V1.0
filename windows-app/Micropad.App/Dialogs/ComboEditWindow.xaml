<Window x:Class="Micropad.App.Dialogs.ComboEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Combo Keys" Height="200" Width="320"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimary}" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Choose two keys that form the chord (e.g. K1 + K2)."
                  Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,16"/>
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Key 1:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" Margin="0,0,12,0"/>
            <ComboBox x:Name="Key1Combo" Grid.Column="1" MinWidth="120"/>
        </Grid>
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Key 2:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" Margin="0,0,12,0"/>
            <ComboBox x:Name="Key2Combo" Grid.Column="1" MinWidth="120"/>
        </Grid>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" IsCancel="True" Width="80" Padding="10,6" Margin="0,0,8,0"
                    Background="{StaticResource BgTertiary}" Foreground="{StaticResource TextPrimary}" BorderThickness="0" Cursor="Hand"/>
            <Button Content="OK" IsDefault="True" Width="80" Padding="10,6" Click="Ok_Click"
                    Background="{StaticResource AccentPrimary}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
